sdk.dir=C\:\\Users\\YOUR_USER\\AppData\\Local\\Android\\Sdk

# ─── ACTION REQUIRED (Step 1) ────────────────────────────────────────────────
# Free Mapbox public token: https://account.mapbox.com/access-tokens/
# Starts with "pk.eyJ1..."
MAPBOX_PUBLIC_TOKEN=pk.PASTE_YOUR_PUBLIC_TOKEN_HERE

# ─── ACTION REQUIRED (Step 2) — optional ────────────────────────────────────
# Free Supabase project: https://supabase.com → Settings → API
# Only needed if you enable saved-places sync (currently disabled)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
# ─────────────────────────────────────────────────────────────────────────────
