<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Main app theme: LIGHT (predictable colors regardless of phone dark mode) -->
    <style name="Theme.UzNavigator" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@android:color/white</item>

        <!-- Transparent status bar so map shows through -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Force light text colors regardless of system dark mode -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
    </style>

    <style name="Theme.UzNavigator.Navigation" parent="Theme.UzNavigator">
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Speed limit widget text styles -->
    <style name="SpeedLimitNumber">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@android:color/black</item>
    </style>

    <style name="SpeedLimitLabel">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/speed_unknown_text</item>
    </style>

    <!-- HUD text styles -->
    <style name="HudDistance">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/nav_hud_text</item>
    </style>

    <style name="HudStreetName">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/nav_hud_secondary</item>
    </style>
</resources>
