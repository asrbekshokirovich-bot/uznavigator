<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <com.mapbox.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ─── Top HUD: next maneuver ─── -->
    <LinearLayout
        android:id="@+id/hudPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@color/nav_hud_bg"
        android:gravity="center_vertical"
        android:minHeight="80dp"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/maneuverIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_directions"
            android:tint="@android:color/white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/distanceText"
                style="@style/HudDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—" />

            <TextView
                android:id="@+id/streetNameText"
                style="@style/HudStreetName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Calculating…" />
        </LinearLayout>

        <!-- ETA chip (top-right) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/etaText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/nav_hud_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/totalDistanceText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/nav_hud_secondary"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ─── BIG SPEED LIMIT WIDGET (UZ road-sign style) ─── -->
    <!-- Anchored bottom-right, ~3.5x previous size -->
    <com.uznavigator.app.ui.BigSpeedLimitView
        android:id="@+id/speedLimitView"
        android:layout_width="180dp"
        android:layout_height="220dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="32dp" />

    <!-- ─── Stop button (solid red pill) ─── -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/stopNavBtn"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="48dp"
        android:paddingHorizontal="28dp"
        android:text="@string/stop_navigation"
        android:textAllCaps="true"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/stop_btn_bg"
        app:cornerRadius="28dp"
        app:elevation="8dp"
        app:icon="@android:drawable/ic_menu_close_clear_cancel"
        app:iconGravity="textStart"
        app:iconTint="@android:color/white" />

    <!-- ─── Re-center camera button (shown only when user pans away) ─── -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/recenterFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="120dp"
        android:contentDescription="@string/my_location"
        android:src="@android:drawable/ic_menu_mylocation"
        android:visibility="gone"
        app:backgroundTint="@android:color/white"
        app:fabCustomSize="52dp"
        app:maxImageSize="26dp"
        app:tint="@color/primary" />

</FrameLayout>
